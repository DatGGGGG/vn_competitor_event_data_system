# Copy this file to deploy/docker/vm.env on the Ubuntu VM and fill in the values.

# Directory on the VM host that contains warehouse.db
HOST_DATA_DIR=/opt/vn_event_dw/data

# Directory on the VM host that stores replayable Sensor Tower raw snapshots
HOST_INGEST_DIR=/opt/vn_event_dw/data_ingest

# Directory on the VM host that stores mounted secret files, including the
# Socialdata Google service-account JSON used for unattended refresh
HOST_SECRETS_DIR=/opt/vn_event_dw/secrets

# Public persistent ngrok configuration
NGROK_AUTHTOKEN=replace_me
NGROK_DOMAIN=replace_me.ngrok-free.dev

# Optional host ports for local inspection on the VM
API_PORT=8765
NGROK_INSPECT_PORT=4040
