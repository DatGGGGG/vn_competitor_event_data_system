# Runtime secrets and pipeline knobs for VM-side API + scheduled ETL jobs.
# Copy this file to deploy/docker/pipeline.env on the Ubuntu VM and fill in the values.

# Sensor Tower
SENSOR_TOWER_AUTH_TOKEN=replace_me
SENSOR_TOWER_BASE_URL=https://api.sensortower.com

# Socialdata
SOCIALDATA_BASE_URL=https://socialdata.garena.vn
SOCIALDATA_TIMEOUT_SECONDS=60
SOCIALDATA_APP_SLUG=srcvn

# Choose one Socialdata auth path:
# 1. Unattended recommended: mount the service-account JSON into /app/secrets
# 2. Temporary/manual fallback: paste a fresh usession or short-lived Google access token
SOCIALDATA_GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/socialdata-service-account.json
SOCIALDATA_USESSION=
SOCIALDATA_GOOGLE_ACCESS_TOKEN=

# OpenAI-compatible Compass Gateway
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://compass.llm.shopee.io/compass-api/v1
OPENAI_PROVIDER=OpenAI
OPENAI_MODEL=gpt-5.4-nano
OPENAI_FB_MERGE_MODEL=gpt-5.4-mini
OPENAI_UNIFIED_EVENT_MERGE_MODEL=gpt-5.4
OPENAI_TIMEOUT_SECONDS=300
OPENAI_MAX_RETRIES=3

# Scheduled pipeline defaults
SOCIALDATA_SYNC_LOOKBACK_DAYS=10
SENSORTOWER_SYNC_LOOKBACK_DAYS=3

# Optional override. Comma-separated YYYY-MM list.
# When blank, the VM pipeline script rebuilds previous month + current month.
PIPELINE_UNIFIED_MONTHS=
