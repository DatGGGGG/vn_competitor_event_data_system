# Copy this file to /etc/vn-event-dw-api.env on the Ubuntu VM

REPO_DIR=/opt/vn_event_dw/vn_competitor_event_data_system
VENV_DIR=/opt/vn_event_dw/vn_competitor_event_data_system/.venv
DB_PATH=/opt/vn_event_dw/vn_competitor_event_data_system/data/warehouse.db

# API bind settings
HOST=127.0.0.1
PORT=8765

# ngrok persistent tunnel settings
NGROK_AUTHTOKEN=replace_me
NGROK_DOMAIN=replace_me.ngrok-free.dev

# Optional OpenAI / Sensor Tower settings if you also run ETL jobs on this VM
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_PROVIDER=
OPENAI_MODEL=
OPENAI_UNIFIED_EVENT_MERGE_MODEL=
SENSOR_TOWER_AUTH_TOKEN=
SENSOR_TOWER_BASE_URL=
